# Copie este arquivo para .env em ambiente local (nunca comite o .env de verdade).
# No Railway, configure estas mesmas variáveis em Settings → Variables.

# Chave secreta que o cliente usa para publicar o catálogo pelo painel.
# Gere uma aleatória forte, ex.: openssl rand -hex 32
CATALOG_TOKEN=

# Personal Access Token do GitHub com permissão de escrita (Contents) apenas neste repositório.
# Recomendado: fine-grained token, "Contents: Read and write", restrito a este repo.
GITHUB_TOKEN=

# Repositório no formato "usuario/repositorio"
GITHUB_REPO=

# Branch onde o trends-data.js será atualizado (padrão: main)
GITHUB_BRANCH=main

# Caminho relativo do arquivo de catálogo (padrão: trends-data.js)
GITHUB_FILE_PATH=trends-data.js

# Ative quando houver exatamente um proxy reverso confiável na frente do app
# (como no Railway), para o rate limit identificar o IP real do cliente.
TRUST_PROXY=1
