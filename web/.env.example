# =========================================================================
# Variáveis de ambiente do painel admin (/admin) e das rotas /api.
# Copie para .env.local e preencha. NUNCA versione o .env.local.
# =========================================================================

# Chave de acesso do painel (mínimo 32 caracteres). Gere uma aleatória:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CATALOG_TOKEN=

# Token do GitHub (fine-grained, com permissão de Contents: read/write no repo)
GITHUB_TOKEN=

# Repositório de destino no formato usuario/repositorio
GITHUB_REPO=

# Branch onde os commits são feitos (padrão: main)
GITHUB_BRANCH=main

# Caminho do módulo de dados da coleção dentro do repo (padrão abaixo)
GITHUB_DATA_PATH=web/lib/trends.ts

# Pasta onde as imagens enviadas são commitadas (padrão abaixo)
GITHUB_IMAGES_DIR=web/public/imgs

# URL pública do site (usada para metadados Open Graph). Ex.: https://veronicachaves.com
SITE_URL=http://localhost:3000
