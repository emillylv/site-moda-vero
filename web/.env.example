# =========================================================================
# Variáveis exclusivamente server-side do painel admin (/admin).
# Copie para .env.local e preencha. NUNCA versione o .env.local.
# =========================================================================

# Hash scrypt da senha (a senha em si não fica no ambiente). Gere interativamente:
#   npm run admin:hash-password
ADMIN_PASSWORD_HASH=

# Assina sessões curtas. Deve ser diferente da senha e ter pelo menos 32 bytes:
#   openssl rand -base64 48
ADMIN_SESSION_SECRET=

# Token do GitHub (fine-grained, com permissão de Contents: read/write no repo)
GITHUB_TOKEN=

# Repositório de destino no formato usuario/repositorio
GITHUB_REPO=

# Branch onde os commits são feitos (padrão: main)
GITHUB_BRANCH=main

# Caminho do JSON da coleção dentro do repo (padrão abaixo)
GITHUB_DATA_PATH=web/data/trends.json

# Pasta onde as imagens enviadas são commitadas (padrão abaixo)
GITHUB_IMAGES_DIR=web/public/imgs

# Origem pública EXATA. Em produção deve usar HTTPS; também protege contra CSRF.
SITE_URL=http://localhost:3000

# Ative somente se o app estiver atrás de um proxy confiável que sobrescreve
# X-Real-IP/X-Forwarded-For (Vercel/Railway bem configurado, por exemplo).
TRUST_PROXY=0
